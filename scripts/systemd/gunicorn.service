[Unit]
Description=PortPax API (Gunicorn)
After=network.target postgresql.service

[Service]
User=git
Group=git
WorkingDirectory=/home/git/backend
Environment="PATH=/home/git/backend/.venv/bin"
ExecStart=/home/git/backend/.venv/bin/gunicorn --bind 127.0.0.1:8000 --workers 2 --timeout 120 --graceful-timeout 30 --error-logfile /var/log/gunicorn.log --access-logfile /var/log/gunicorn-access.log --log-level info config.wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
