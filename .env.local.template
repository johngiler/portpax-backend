# LOCAL — copy to .env (not versioned)
# Used by Django local_settings and by docker compose (Postgres).

DJANGO_SECRET_KEY=django-insecure-local-only-change-me
DEBUG=true

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DB=portpax
POSTGRES_USER=portpax
POSTGRES_PASSWORD=change-me-local
POSTGRES_HOST=127.0.0.1
# Host port mapped by docker-compose. Use 5433 if another project already uses 5432.
POSTGRES_PORT=5433

